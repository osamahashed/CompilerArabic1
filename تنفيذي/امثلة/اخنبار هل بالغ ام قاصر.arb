برنامج اختبار_كامل;
{
    متغير اسم : خيط رمزي;
    متغير عمر : صحيح;

    اجراء ترحيب(بالقيمة ن : خيط رمزي)
    {
        اطبع("أهلاً بك يا", ن);
    };

    اطبع("أدخل اسمك:");
    اقرأ(اسم);

    ترحيب(اسم);

    اطبع("أدخل عمرك:");
    اقرأ(عمر);

    اذا (عمر >= 18) فان {
        اطبع("أنت بالغ");
    } والا {
        اطبع("أنت قاصر");
    };

}
.