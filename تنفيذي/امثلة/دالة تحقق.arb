برنامج متداخل;
{
    متغير i : صحيح;
    متغير j : صحيح;

    كرر(i = 1 الى 3 اضف 1) {
        كرر(j = 1 الى 3 اضف 1) {
            اذا ( (i * j) % 2 == 0 ) فان {
                اطبع("i:", i, "j:", j, "الناتج زوجي");
            } والا {
                اطبع("i:", i, "j:", j, "الناتج فردي");
            };
        };
    };
}
.